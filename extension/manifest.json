{
  "manifest_version": 3,
  "name": "Fornello Recipe Importer",
  "version": "1.2.0",
  "description": "Save recipes from any website — including Instagram, TikTok, YouTube and Pinterest — straight into your Fornello family meal planner.",
  "author": "Chez Toi",
  "homepage_url": "https://www.fornello.app",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.fornello.app/*",
    "https://fornello.app/*",
    "http://localhost:3001/*",
    "http://localhost:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
