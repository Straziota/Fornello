\f1\b * (Optional) Ingredients for homemade pasta\
\
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls8\ilvl0\cf2 {\listtext	\uc0\u8226 	}
\f2\b0 500 g all purpose flour \
{\listtext	\uc0\u8226 	}5 whole eggs\
{\listtext	\uc0\u8226 	}1 tsp salt\
{\listtext	\uc0\u8226 	}5 Tbsp water\
\pard\tx720\pardeftab720\partightenfactor0
\cf2 \
